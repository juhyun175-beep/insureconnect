/robots.txt
  Content-Type: text/plain; charset=utf-8

/ads.txt
  Content-Type: text/plain; charset=utf-8

/sitemap.xml
  Content-Type: application/xml; charset=utf-8

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()
  Strict-Transport-Security: max-age=63072000
  X-XSS-Protection: 0

# HTML은 매번 새로 가져오되 stale-while-revalidate로 체감속도 ↑ (1분 fresh + 10분 background revalidate)
# v2.74.0: 루트(/)는 /index.html 규칙에 안 잡혀 기본 max-age=0(매번 재검증)로 떨어지던 버그 → 명시적 규칙 추가
/
  Cache-Control: public, max-age=60, stale-while-revalidate=600
/index.html
  Cache-Control: public, max-age=60, stale-while-revalidate=600
/admin.html
  X-Frame-Options: DENY
  X-Robots-Tag: noindex, nofollow, noarchive, nosnippet
  Cache-Control: private, no-cache, no-store, must-revalidate
  Pragma: no-cache
  Cross-Origin-Opener-Policy: same-origin

# Service Worker는 절대 캐시 금지 — 옛 SW가 영구히 박히는 문제 방지
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: application/javascript

# 이미지: 1년 캐시 (immutable - 같은 파일명이면 절대 안 바뀐다고 가정)
/*.png
  Cache-Control: public, max-age=31536000, immutable
/*.jpg
  Cache-Control: public, max-age=31536000, immutable
/*.jpeg
  Cache-Control: public, max-age=31536000, immutable
/*.webp
  Cache-Control: public, max-age=31536000, immutable
/*.svg
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable

# v2.123.0: 배포 시 외부화된 인라인 JS/CSS (scripts/externalize.mjs — 내용해시 파일명이라 영구 캐시 안전)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# 폰트/CSS: 1년 캐시 (JS는 sw.js 캐시 충돌 방지 위해 일반 룰 제거 — root에 .js는 sw.js뿐)
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable
